# Backend environment example
# Copy to .env.local and fill in values.

# Mode: "http" (default) or "mcp"
BACKEND_MODE=http

# HTTP server
MCP_HOST=127.0.0.1
PORT=8080
LOG_LEVEL=info

# Databricks (required for live cluster APIs)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_TIMEOUT_MS=15000
DATABRICKS_RETRY_ATTEMPTS=3
DATABRICKS_RETRY_DELAY_SECONDS=1

# Failure email reporting after Databricks Jobs/Pipelines retries are exhausted
ALERT_EMAIL_TO=arushverma767@gmail.com
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Optional: Claude/Anthropic (only needed once chat orchestration is wired)
ANTHROPIC_API_KEY=

# CORS (dev)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Optional: Supabase (server-side; only needed if backend persistence is added)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
